# Example secrets file for Streamlit Community Cloud.
# In the Streamlit Cloud dashboard: App settings -> Secrets, paste contents like this.
# Locally: copy this file to .streamlit/secrets.toml (do NOT commit secrets.toml).

GEMINI_API_KEY = "your-google-ai-studio-api-key-here"

# Optional: gate the app with a shared password so only your wife can use it.
# Leave empty string to disable the password gate.
APP_PASSWORD = "pick-a-strong-shared-password"
